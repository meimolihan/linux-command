/* 壁纸切换功能 */
const WALLPAPER_API = 'https://api.meimolihan.eu.org/';
const HONEYCOMB_BG = 'linear-gradient(30deg, rgba(102, 126, 234, 0.05) 12%, transparent 12.5%, transparent 87%, rgba(102, 126, 234, 0.05) 87.5%), linear-gradient(150deg, rgba(102, 126, 234, 0.05) 12%, transparent 12.5%, transparent 87%, rgba(102, 126, 234, 0.05) 87.5%), linear-gradient(30deg, rgba(102, 126, 234, 0.05) 12%, transparent 12.5%, transparent 87%, rgba(102, 126, 234, 0.05) 87.5%), linear-gradient(150deg, rgba(102, 126, 234, 0.05) 12%, transparent 12.5%, transparent 87%, rgba(102, 126, 234, 0.05) 87.5%), linear-gradient(60deg, rgba(118, 75, 162, 0.04) 25%, transparent 25.5%, transparent 75%, rgba(118, 75, 162, 0.04) 75%), linear-gradient(60deg, rgba(118, 75, 162, 0.04) 25%, transparent 25.5%, transparent 75%, rgba(118, 75, 162, 0.04) 75%)';

function toggleWallpaper() {
  const isRandom = document.body.classList.contains('wallpaper-random');
  const isLocal = document.body.classList.contains('wallpaper-local');
  if (isRandom || isLocal) {
    // 关闭壁纸，切换到另一个模式
    document.body.classList.remove('wallpaper-random');
    document.body.classList.remove('wallpaper-local');
    if (isRandom) {
      // 从随机切换到本地
      applyHoneycombBg();
      localStorage.setItem('_wallpaper_mode_', 'local');
      syncWallpaperUI(false);
    } else {
      // 从本地切换到随机
      document.body.classList.add('wallpaper-random');
      localStorage.setItem('_wallpaper_ts_', Date.now());
      applyWallpaperBg();
      localStorage.setItem('_wallpaper_mode_', 'on');
      syncWallpaperUI(true);
    }
  } else {
    // 首次开启随机壁纸
    document.body.classList.add('wallpaper-random');
    localStorage.setItem('_wallpaper_ts_', Date.now());
    applyWallpaperBg();
    localStorage.setItem('_wallpaper_mode_', 'on');
    syncWallpaperUI(true);
  }
}

// 页面加载时恢复壁纸状态，并监控 body 背景变化
(function initWallpaper() {
  const mode = localStorage.getItem('_wallpaper_mode_');
  if (mode !== 'on' && mode !== 'local') return;

  // 延迟设置，让 body 先完成渲染
  requestAnimationFrame(function() {
    requestAnimationFrame(function() {
      if (mode === 'on') {
        document.body.classList.add('wallpaper-random');
        applyWallpaperBg();
        syncWallpaperUI(true);
      } else if (mode === 'local') {
        applyHoneycombBg();
        syncWallpaperUI(false);
      }
    });
  });

  // 监控 body.style 的变化，被覆盖时自动恢复
  var wallpaperObserver = new MutationObserver(function(records) {
    for (var i = 0; i < records.length; i++) {
      var rec = records[i];
      if (rec.type === 'attributes' && rec.attributeName === 'style') {
        var currentBg = document.body.style.backgroundImage;
        if (!currentBg || currentBg === 'none' || currentBg === '') {
          if (mode === 'on') applyWallpaperBg();
          else if (mode === 'local') applyHoneycombBg();
        }
      }
    }
  });
  wallpaperObserver.observe(document.body, { attributes: true });

  // 备用：定期检查（每 200ms），防止其他方式覆盖背景
  setInterval(function() {
    var currentMode = localStorage.getItem('_wallpaper_mode_');
    if (document.body.classList.contains('wallpaper-random')) {
      var bg = document.body.style.backgroundImage;
      if (!bg || bg === 'none' || bg === '') {
        applyWallpaperBg();
      }
    } else if (currentMode === 'local') {
      var bg = document.body.style.backgroundImage;
      if (!bg || bg === 'none' || bg === '') {
        applyHoneycombBg();
      }
    }
  }, 200);
})();

function applyWallpaperBg() {
  var ts = localStorage.getItem('_wallpaper_ts_') || Date.now();
  var bgUrl = "url('" + WALLPAPER_API + "?t=" + ts + "')";
  document.body.style.backgroundImage = bgUrl;
  document.documentElement.style.backgroundImage = bgUrl;
  document.body.classList.add('wallpaper-random');
}

function applyHoneycombBg() {
  document.body.classList.add('wallpaper-local');
  document.body.style.backgroundImage = HONEYCOMB_BG;
  document.body.style.backgroundSize = '56px 98px';
  document.body.style.backgroundPosition = '0 0, 0 0, 28px 49px, 28px 49px, 0 0, 28px 49px';
  document.documentElement.style.backgroundImage = HONEYCOMB_BG;
  document.documentElement.style.backgroundSize = '56px 98px';
  document.documentElement.style.backgroundPosition = '0 0, 0 0, 28px 49px, 28px 49px, 0 0, 28px 49px';
}

function syncWallpaperUI(isOn) {
  var icoR = document.getElementById('wallpaper-icon-random');
  var icoL = document.getElementById('wallpaper-icon-local');
  var lbl = document.getElementById('wallpaper-label');
  if (!icoR || !icoL || !lbl) return;
  if (isOn) {
    icoR.style.display = 'none';
    icoL.style.display = '';
    lbl.textContent = '本地';
  } else {
    icoR.style.display = '';
    icoL.style.display = 'none';
    lbl.textContent = '随机';
  }
}
</script>