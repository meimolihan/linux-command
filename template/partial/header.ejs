<script>
function toggleTheme() {
  const html = document.documentElement;
  const sunBg = document.getElementById('sun-bg');
  const moonBg = document.getElementById('moon-bg');
  const themeToggle = document.getElementById('theme-toggle');
  if (html.getAttribute('data-color-mode') === 'dark') {
    html.setAttribute('data-color-mode', 'light');
    localStorage.setItem('_dark_mode_theme_', 'light');
    sunBg.style.display = 'none';
    moonBg.style.display = 'flex';
    themeToggle.style.background = 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)';
    themeToggle.style.boxShadow = '0 4px 15px rgba(102, 126, 234, 0.4)';
  } else {
    html.setAttribute('data-color-mode', 'dark');
    localStorage.setItem('_dark_mode_theme_', 'dark');
    sunBg.style.display = 'flex';
    moonBg.style.display = 'none';
    themeToggle.style.background = 'linear-gradient(135deg, #58a6ff 0%, #79c0ff 100%)';
    themeToggle.style.boxShadow = '0 4px 15px rgba(88, 166, 255, 0.4)';
  }
}
const savedTheme = localStorage.getItem('_dark_mode_theme_');
const sunBg = document.getElementById('sun-bg');
const moonBg = document.getElementById('moon-bg');
const themeToggle = document.getElementById('theme-toggle');
if (savedTheme === 'dark' || savedTheme === null) {
  document.documentElement.setAttribute('data-color-mode', 'dark');
  document.getElementById('sun-bg').style.display = 'flex';
  document.getElementById('moon-bg').style.display = 'none';
  themeToggle.style.background = 'linear-gradient(135deg, #58a6ff 0%, #79c0ff 100%)';
  themeToggle.style.boxShadow = '0 4px 15px rgba(88, 166, 255, 0.4)';
} else if (savedTheme === 'light') {
  document.documentElement.setAttribute('data-color-mode', 'light');
  sunBg.style.display = 'none';
  moonBg.style.display = 'flex';
  themeToggle.style.background = 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)';
  themeToggle.style.boxShadow = '0 4px 15px rgba(102, 126, 234, 0.4)';
}
</script>
