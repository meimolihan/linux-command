<%- include('partial/header'); %>
<%- include('widget/search',{type: "list"}); %>
<!-- ⑯ 骨架屏（真实内容加载前短暂显示） -->
<div class="skeleton-wrap" id="page-skeleton" style="display:none;">
  <div class="skeleton-block sk-header"></div>
  <div class="skeleton-block sk-tagline"></div>
  <div class="skeleton-block sk-divider"></div>
  <div class="skeleton-block sk-row"></div>
  <div class="skeleton-block sk-row"></div>
  <div class="skeleton-block sk-row-sm"></div>
  <div class="skeleton-block sk-row-sm"></div>
  <div class="skeleton-block sk-row"></div>
</div>

<div class="list-banner banner-all">
  <div class="list-banner-inner">
    <div class="banner-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
        <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
      </svg>
    </div>
    <div class="banner-content">
      <h2 class="banner-title">命令与脚本大全</h2>
      <p class="banner-desc">共收录 <span class="banner-count command-count"><%=describe.command_length?describe.command_length:'0'%></span> 个命令、<span class="banner-count script-count"><%=describe.script_length?describe.script_length:'0'%></span> 个脚本，共计 <span class="banner-count total-count"><%=describe.total_length?describe.total_length:'0'%></span> 条内容</p>
    </div>
  </div>
</div>

<div class="hotlist">
  <div class="list-title">
    <h3 class="section-title command-title">
      <span class="section-icon-wrap">
        <svg class="section-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
        </svg>
      </span>
      Linux 命令
    </h3>
  </div>
  <ul class="command-list">
  <%describe.arr.filter(function(item){return item.t==="command"}).forEach(function(page,item){%>
    <li><a href="c<%=page.p%>.html"><strong><%=page.n%></strong> - <%=page.d%></a></li>
  <%});%>
  </ul>

  <div class="list-title" style="margin-top:30px;">
    <h3 class="section-title script-section">
      <span class="section-icon-wrap">
        <svg class="section-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="16 18 22 12 16 6"/>
          <polyline points="8 6 2 12 8 18"/>
        </svg>
      </span>
      Shell 脚本
    </h3>
  </div>
  <ul class="command-list">
  <%describe.arr.filter(function(item){return item.t==="script"}).forEach(function(page,item){%>
    <li><a href="c<%=page.p%>.html"><strong><%=page.n%></strong> - <%=page.d%></a></li>
  <%});%>
  </ul>
</div>
<%- include('widget/footer',{type: "list"}); %>
<%- include('partial/footer'); %>
