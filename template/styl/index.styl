@import('mixins/reset.styl')
@import('mixins/markdown.styl')

mq-mobile = "screen and (max-width: 479px)"

[data-color-mode*='dark'], [data-color-mode*='dark'] body {
  color-scheme: dark;
  --color-header-bg: #3a3a3a8f;
  --color-header-border: #323232;
  --color-hover: #ffffff30;
  --color-code-bg: #1e1e1e;
  --color-theme-bg: #0d1117;
  --color-card-bg: #161b22;
  --color-blur-bg: rgba(22, 27, 34, 0.85);
  --color-search-btn-bg: linear-gradient(135deg, #58a6ff 0%, #79c0ff 100%);
  --color-search-btn-hover-shadow: rgba(88, 166, 255, 0.4);
  --color-search-btn-pulse: linear-gradient(135deg, #58a6ff 0%, #79c0ff 100%);
  --color-footer-bg: #161b22;
  --color-footer-border: rgba(255, 255, 255, 0.15);
  --color-footer-text: #c9d1d9;
  --color-input-border: #30363d;
}
[data-color-mode*='light'], [data-color-mode*='light'] body {
  color-scheme: light;
  --color-theme-bg: linear-gradient(135deg, rgba(255,255,255,0.95) 0%, rgba(245,247,250,0.95) 100%);
  --color-code-bg: #f0f2f5;
  --color-header-bg: rgba(255, 255, 255, 0.85);
  --color-header-border: rgba(226, 232, 240, 0.8);
  --color-hover: rgba(88, 166, 255, 0.08);
  --color-search-btn-bg: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  --color-search-btn-hover-shadow: rgba(102, 126, 234, 0.4);
  --color-search-btn-pulse: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  --color-footer-bg: rgba(255, 255, 255, 0.85);
  --color-footer-border: rgba(88, 166, 255, 0.15);
  --color-footer-text: #4a5568;
  --color-input-border: rgba(226, 232, 240, 0.8);
  --color-card-bg: rgba(255, 255, 255, 0.85);
  --color-blur-bg: rgba(255, 255, 255, 0.85);
}

[data-color-mode*='light'] {
  /* 明亮模式 Header 列表页固定导航 - 白色半透明磨砂 */
  .header.header_list {
    background rgba(255, 255, 255, 0.65)
    backdrop-filter blur(12px) saturate(180%)
    -webkit-backdrop-filter blur(12px) saturate(180%)
    border-bottom 1px solid rgba(102, 126, 234, 0.12)
  }
  /* 暗色模式 Header 列表页 - 黑色半透明磨砂 */
  [data-color-mode*='dark'] .header.header_list,
  html:not([data-color-mode]) .header.header_list {
    background rgba(13, 17, 23, 0.65)
    backdrop-filter blur(12px) saturate(180%)
    -webkit-backdrop-filter blur(12px) saturate(180%)
    border-bottom 1px solid rgba(255, 255, 255, 0.08)
  }
  /* 搜索框输入 - 白色半透明磨砂 */
  .header .search .query {
    background rgba(255, 255, 255, 0.65)
    backdrop-filter blur(10px) saturate(180%)
    -webkit-backdrop-filter blur(10px) saturate(180%)
    border 1px solid rgba(102, 126, 234, 0.15)
    color #333
    &:focus {
      background rgba(255, 255, 255, 0.8)
      box-shadow 0 0 0 3px rgba(102, 126, 234, 0.15)
      border-color rgba(102, 126, 234, 0.25)
    }
  }
  /* 暗色模式搜索框 - 黑色半透明磨砂 */
  [data-color-mode*='dark'] .header .search .query,
  html:not([data-color-mode]) .header .search .query {
    background rgba(13, 17, 23, 0.65)
    backdrop-filter blur(10px) saturate(180%)
    -webkit-backdrop-filter blur(10px) saturate(180%)
    border 1px solid rgba(255, 255, 255, 0.1)
    color #c9d1d9
    &:focus {
      background rgba(13, 17, 23, 0.8)
      box-shadow 0 0 0 3px rgba(88, 166, 255, 0.15)
      border-color rgba(88, 166, 255, 0.25)
    }
  }
  .logo::before {
    background radial-gradient(ellipse, rgba(88, 166, 255, 0.15) 0%, transparent 70%)
  }
  .logo a:hover {
    filter drop-shadow(0 4px 12px rgba(88, 166, 255, 0.3))
  }
  /* 搜索结果下拉列表 - 白色半透明磨砂 */
  .search-list {
    background rgba(255, 255, 255, 0.65)
    backdrop-filter blur(14px) saturate(180%)
    -webkit-backdrop-filter blur(14px) saturate(180%)
    border 1px solid rgba(102, 126, 234, 0.12)
  }
  /* 暗色模式搜索结果下拉 - 黑色半透明磨砂 */
  [data-color-mode*='dark'] .search-list,
  html:not([data-color-mode]) .search-list {
    background rgba(13, 17, 23, 0.65)
    backdrop-filter blur(14px) saturate(180%)
    -webkit-backdrop-filter blur(14px) saturate(180%)
    border 1px solid rgba(255, 255, 255, 0.08)
  }
  /* Footer 背景 - 白色半透明磨砂 */
  .footer .footer-warp {
    background rgba(255, 255, 255, 0.65)
    backdrop-filter blur(14px) saturate(180%)
    -webkit-backdrop-filter blur(14px) saturate(180%)
    border 1px solid rgba(102, 126, 234, 0.1)
  }
  /* 暗色模式 Footer - 黑色半透明磨砂 */
  [data-color-mode*='dark'] .footer .footer-warp,
  html:not([data-color-mode]) .footer .footer-warp {
    background rgba(13, 17, 23, 0.65)
    backdrop-filter blur(14px) saturate(180%)
    -webkit-backdrop-filter blur(14px) saturate(180%)
    border 1px solid rgba(255, 255, 255, 0.08)
  }
  /* Footer 按钮 - 白色半透明磨砂 */
  .footer-item {
    background rgba(255, 255, 255, 0.65)
    backdrop-filter blur(10px) saturate(180%)
    border 1px solid rgba(102, 126, 234, 0.12)
    padding 8px 6px !important
    font-size 13px !important
    border-radius 6px !important
  }
  /* 暗色模式 Footer 按钮 - 黑色半透明磨砂 */
  [data-color-mode*='dark'] .footer-item,
  html:not([data-color-mode]) .footer-item {
    background rgba(13, 17, 23, 0.65)
    backdrop-filter blur(10px) saturate(180%)
    border 1px solid rgba(255, 255, 255, 0.08)
  }
  .nav-link {
    background var(--color-blur-bg)
    backdrop-filter blur(8px)
  }
}

.warpper {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  .footer {
    padding-bottom: 280px;
  }
}

.header {
  width 517px
  margin 0 auto 0
  padding 0 10px
  position relative
  z-index 99900
  border-radius 15px
  .logo a {
    display flex
    color: currentColor
    position relative
    overflow hidden
    transition transform 0.3s cubic-bezier(0.4, 0, 0.2, 1)
    &:hover {
      transform scale(1.03)
      filter drop-shadow(0 4px 12px rgba(102, 126, 234, 0.3))
    }
    &:active {
      transform scale(0.98)
    }
  }

  /* Logo 动画增强 */
  .logo {
    position relative
    &::before {
      content ''
      position absolute
      top 50%
      left 50%
      width 160px
      height 60px
      transform translate(-50%, -50%)
      background radial-gradient(ellipse, rgba(102, 126, 234, 0.15) 0%, transparent 70%)
      opacity 0
      transition opacity 0.5s ease
      pointer-events none
      z-index -1
    }
    &:hover::before {
      opacity 1
      animation logoGlow 2s ease-in-out infinite
    }
  }

  .box {
    position relative
  }
  .search {
    position relative
    display table
    border-collapse separate
    z-index 99995
    li,ul {
      list-style none
    }
    #result {
      .ok {
        background:#f4f4f4;
      }
    }
    .search-list {
      position absolute
      display none
      z-index 99990
      box-shadow 0 8px 32px rgba(0,0,0,0.12), 0 2px 8px rgba(0,0,0,0.06)
      border 1px solid rgba(102,126,234,0.2)
      background rgba(255, 255, 255, 0.92)
      backdrop-filter blur(16px) saturate(180%)
      -webkit-backdrop-filter blur(16px) saturate(180%)
      min-width 100px
      top 39px
      width 100%
      padding 8px
      border-radius 14px
      opacity 0
      pointer-events none
      transition opacity 0.15s ease
      /* 首页搜索下拉 - 命令卡片 */
      li.command-item {
        margin-bottom 6px
        padding 0
        list-style-type none
        border-radius 10px
        overflow hidden
        background rgba(102, 126, 234, 0.1)
        backdrop-filter blur(8px) saturate(180%)
        -webkit-backdrop-filter blur(8px) saturate(180%)
        border 1px solid rgba(102, 126, 234, 0.2)
        border-left 3px solid rgba(102, 126, 234, 0.5)
        transition all 0.25s cubic-bezier(0.4, 0, 0.2, 1)
        &:hover {
          background rgba(102, 126, 234, 0.18)
          border-left-color #667eea
          transform translateX(4px)
        }
      }
      /* 首页搜索下拉 - 脚本卡片 */
      li.script-item {
        margin-bottom 6px
        padding 0
        list-style-type none
        border-radius 10px
        overflow hidden
        background rgba(240, 147, 251, 0.1)
        backdrop-filter blur(8px) saturate(180%)
        -webkit-backdrop-filter blur(8px) saturate(180%)
        border 1px solid rgba(240, 147, 251, 0.2)
        border-left 3px solid rgba(240, 147, 251, 0.5)
        transition all 0.25s cubic-bezier(0.4, 0, 0.2, 1)
        &:hover {
          background rgba(240, 147, 251, 0.18)
          border-left-color #f093fb
          transform translateX(4px)
        }
      }
      /* 通用卡片样式 */
      li {
        margin-bottom 6px
        padding 0
        list-style-type none
        border-radius 10px
        overflow hidden
        background rgba(255, 255, 255, 0.72)
        backdrop-filter blur(8px) saturate(180%)
        -webkit-backdrop-filter blur(8px) saturate(180%)
        border 1px solid rgba(102, 126, 234, 0.15)
        border-left 3px solid rgba(102, 126, 234, 0.3)
        transition all 0.25s cubic-bezier(0.4, 0, 0.2, 1)
        &:hover {
          background rgba(255, 255, 255, 0.92)
          border-left-color #667eea
          transform translateX(4px)
        }
        span{
          padding 0 8px
          color #b9b9b9
        }
      }
      a {
        display block
        padding 10px 14px
        border-radius 0
        font-size 14px
        transition all 0.25s cubic-bezier(0.4, 0, 0.2, 1)
        position relative
        strong {
          font-weight bold
          color #d6a400
          transition color 0.2s ease
          &:hover {
            color #f0c040
          }
        }
        .kw {
          color #f00
          font-style inherit
          font-weight bold
        }
        &:hover {
          background transparent
          .kw {
            color #667eea
          }
        }
      }
    }
    /* 暗色模式首页搜索下拉 */
    [data-color-mode*='dark'] .search-list,
    html:not([data-color-mode]) .search-list {
      box-shadow 0 8px 32px rgba(0,0,0,0.4), 0 2px 8px rgba(0,0,0,0.2)
      border-color rgba(255,255,255,0.1)
      background rgba(13, 17, 23, 0.92)
      backdrop-filter blur(16px) saturate(180%)
      -webkit-backdrop-filter blur(16px) saturate(180%)
      /* 命令卡片 */
      li.command-item {
        background rgba(88, 166, 255, 0.08)
        backdrop-filter blur(8px) saturate(180%)
        -webkit-backdrop-filter blur(8px) saturate(180%)
        border-color rgba(88, 166, 255, 0.2)
        border-left-color rgba(88, 166, 255, 0.5)
        &:hover {
          background rgba(88, 166, 255, 0.15)
          border-left-color #58a6ff
        }
      }
      /* 脚本卡片 */
      li.script-item {
        background rgba(240, 147, 251, 0.08)
        backdrop-filter blur(8px) saturate(180%)
        -webkit-backdrop-filter blur(8px) saturate(180%)
        border-color rgba(240, 147, 251, 0.2)
        border-left-color rgba(240, 147, 251, 0.5)
        &:hover {
          background rgba(240, 147, 251, 0.15)
          border-left-color #f093fb
        }
      }
      /* 通用卡片 */
      li {
        background rgba(22, 27, 34, 0.72)
        backdrop-filter blur(8px) saturate(180%)
        -webkit-backdrop-filter blur(8px) saturate(180%)
        border-color rgba(255, 255, 255, 0.1)
        border-left-color rgba(255, 255, 255, 0.15)
        &:hover {
          background rgba(22, 27, 34, 0.92)
          border-left-color #58a6ff
        }
      }
      a {
        strong {
          color #f0c040
          &:hover {
            color #ffd700
          }
        }
        .kw {
          color #f85149
          &:hover {
            color #79c0ff
          }
        }
      }
    }
    .query, .enter-input {
      display table-cell
      transition border-color ease-in-out 0.15s, box-shadow ease-in-out 0.15s
    }
    .query {
      resize: none;
      position relative
      z-index 2
      width 100%
      height 40px
      padding 6px 14px
      font-size 14px
      font-weight bold
      line-height 1.42857143
      background-color: transparent;
      background-image none
      border 1px solid transparent
      border-radius 8px 0 0 8px
      -webkit-appearance: none;
      transition all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      position relative
      &::before {
        content ''
        position absolute
        inset 0
        border-radius 8px 0 0 8px
        padding 1px
        background linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%)
        -webkit-mask linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0)
        mask linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0)
        -webkit-mask-composite xor
        mask-composite exclude
        opacity 0.4
        transition opacity 0.3s ease
      }
      &:focus {
        z-index 99
        border-color transparent
        outline 0
        box-shadow 0 0 0 4px rgba(102, 126, 234, 0.25), 0 0 25px rgba(102, 126, 234, 0.2), 0 6px 16px rgba(102, 126, 234, 0.15)
        filter brightness(1.02)
        &::before {
          opacity 1
        }
      }
    }
    .enter-input {
      white-space nowrap
      button {
        margin 0
        left -1px
        position relative
        z-index 5
        display inline-block
        padding 9px 23px
        font-size 14px
        font-weight bold
        line-height 1.42857143
        text-align center
        text-rendering auto
        white-space nowrap
        vertical-align middle
        touch-action manipulation
        cursor pointer
        user-select none
        background-image none
        border 1px solid transparent
        border-radius 0 8px 8px 0
        border-color $border-color
        background var(--color-search-btn-bg)
        color #fff
        transition all 0.3s ease
        overflow hidden
        position relative
        &:focus,&:active:focus {
          outline thin dotted
          outline 5px auto -webkit-focus-ring-color
          outline-offset -2px
        }
        &:active {
          transform scale(0.97)
          box-shadow inset 0 2px 10px rgba(0,0,0,0.2)
        }
        &:focus {
          text-decoration none
        }
        &:hover {
          box-shadow 0 4px 15px var(--color-search-btn-hover-shadow)
          transform translateY(-1px)
        }
      }
    }
  }
}

@keyframes logoGlow {
  0%, 100% {
    transform translate(-50%, -50%) scale(1)
    opacity 0.6
  }
  50% {
    transform translate(-50%, -50%) scale(1.1)
    opacity 1
  }
}

/* Logo 文字动画 */
.logo a {
  svg {
    transition transform 0.4s cubic-bezier(0.4, 0, 0.2, 1), filter 0.4s ease
  }
  &:hover svg {
    transform translateX(4px)
  }
}

/* 首页 Logo 入场动画 */
.header.home .logo {
  animation logoEntrance 0.8s cubic-bezier(0.4, 0, 0.2, 1)
}

@keyframes logoEntrance {
  0% {
    opacity 0
    transform translateY(-20px) scale(0.9)
  }
  60% {
    transform translateY(5px) scale(1.02)
  }
  100% {
    opacity 1
    transform translateY(0) scale(1)
  }
}

.footer {
  text-align center
  padding-top 31px
  font-size 14px
  font-weight 300
  padding 31px 6px 50px 6px
  margin-top 10px !important
  position relative
  z-index 1
  &.home {
    border-top 0
  }
  div {
    font-size 12px
  }
  /* 统一底部 4x2 网格布局 */
  .footer-grid {
    display grid
    grid-template-columns repeat(4, 1fr)
    gap 10px
    max-width 520px
    margin 0 auto
    padding 16px
    background var(--color-card-bg)
    border-radius 16px
    border 1px solid var(--color-footer-border)
    box-shadow 0 2px 12px rgba(102, 126, 234, 0.08)
    backdrop-filter blur(16px) saturate(180%)
    -webkit-backdrop-filter blur(16px) saturate(180%)
    z-index 1
  }
  .footer-item {
    display flex
    align-items center
    justify-content center
    gap 6px
    padding 8px 6px
    border-radius 6px
    border 1px solid var(--color-footer-border)
    color var(--color-footer-text)
    font-weight 500
    font-size 13px
    background transparent
    backdrop-filter blur(8px)
    text-decoration none
    transition all 0.25s cubic-bezier(0.4, 0, 0.2, 1)
    position relative
    overflow hidden
    cursor pointer
    min-width 0
    .footer-icon {
      width 14px
      height 14px
      flex-shrink 0
      transition transform 0.25s ease
    }
    .footer-text {
      white-space nowrap
      overflow hidden
      text-overflow ellipsis
    }
    .footer-count {
      font-weight 700
      margin-left 2px
      font-size 13px
    }
    .footer-count.command {
      color #58a6ff
    }
    .footer-count.script {
      color #f093fb
    }
    .footer-count.total {
      color #f0c040
    }
    &:hover {
      border-color #58a6ff
      color #58a6ff
      background rgba(88, 166, 255, 0.08)
      box-shadow 0 2px 12px rgba(88, 166, 255, 0.2)
      .footer-icon {
        transform scale(1.15)
      }
    }
    &:active {
      border-color #58a6ff
      color #58a6ff
      background rgba(88, 166, 255, 0.12)
      box-shadow 0 1px 4px rgba(88, 166, 255, 0.15)
      transform scale(0.95)
    }
  }

  /* 图标颜色 */
  .footer-icon.icon-command {
    color #fbbf24
  }
  .footer-icon.icon-list {
    color #58a6ff
  }
  .footer-icon.icon-script {
    color #34d399
  }
  .footer-icon.icon-doc {
    color #a78bfa
  }
  .footer-icon.icon-total {
    color #fbbf24
  }
  .footer-icon.icon-github {
    /* 使用 SVG 内置渐变 */
  }

  /* 暗色模式 */
  [data-color-mode*='dark'] & .footer-item {
    padding 8px 6px !important
    border-radius 6px !important
    font-size 13px !important
    background transparent
    border-color rgba(255,255,255,0.15)
    color #c9d1d9
    .footer-icon {
      width 14px
      height 14px
    }
    .footer-count {
      font-size 13px
    }
    &:hover {
      border-color #58a6ff
      color #58a6ff
      background rgba(88, 166, 255, 0.08)
      box-shadow 0 2px 12px rgba(88, 166, 255, 0.2)
    }
    &:active {
      border-color #58a6ff
      color #58a6ff
      background rgba(88, 166, 255, 0.12)
      box-shadow 0 1px 4px rgba(88, 166, 255, 0.15)
      transform scale(0.95)
    }
  }
  [data-color-mode*='dark'] & .footer-item .footer-count.command {
    color #58a6ff
  }
  [data-color-mode*='dark'] & .footer-item .footer-count.script {
    color #f093fb
  }
  [data-color-mode*='dark'] & .footer-item .footer-count.total {
    color #f0c040
  }
  [data-color-mode*='dark'] .footer-icon.icon-command {
    color #fbbf24
  }
  [data-color-mode*='dark'] .footer-icon.icon-list {
    color #58a6ff
  }
  [data-color-mode*='dark'] .footer-icon.icon-script {
    color #34d399
  }
  [data-color-mode*='dark'] .footer-icon.icon-doc {
    color #a78bfa
  }
  [data-color-mode*='dark'] .footer-icon.icon-total {
    color #fbbf24
  }
  [data-color-mode*='dark'] .footer-icon.icon-github {
    color #c9d1d9
  }
  /* 明亮模式 footer-item 与暗色模式完全一致 */
  [data-color-mode*='light'] & .footer-item {
    padding 8px 6px !important
    border-radius 6px !important
    font-size 13px !important
    font-weight 500
    background transparent
    border-color rgba(102, 126, 234, 0.2)
    color #333
    .footer-icon {
      width 14px
      height 14px
    }
    .footer-count {
      font-size 13px
    }
    &:hover {
      border-color #667eea
      color #667eea
      background rgba(102, 126, 234, 0.08)
      box-shadow 0 2px 12px rgba(102, 126, 234, 0.2)
    }
    &:active {
      border-color #667eea
      color #667eea
      background rgba(102, 126, 234, 0.12)
      box-shadow 0 1px 4px rgba(102, 126, 234, 0.15)
      transform scale(0.95)
    }
  }
  [data-color-mode*='light'] & .footer-item .footer-count.command {
    color #667eea
  }
  [data-color-mode*='light'] & .footer-item .footer-count.script {
    color #f093fb
  }
  [data-color-mode*='light'] & .footer-item .footer-count.total {
    color #d6a400
  }
  [data-color-mode*='light'] .footer-icon.icon-command {
    color #f59e0b
  }
  [data-color-mode*='light'] .footer-icon.icon-list {
    color #667eea
  }
  [data-color-mode*='light'] .footer-icon.icon-script {
    color #34d399
  }
  [data-color-mode*='light'] .footer-icon.icon-doc {
    color #8b5cf6
  }
  [data-color-mode*='light'] .footer-icon.icon-total {
    color #f59e0b
  }
  [data-color-mode*='light'] .footer-icon.icon-github {
    color #333
  }
  .nav-link {
    display inline-flex
    align-items center
    gap 6px
    padding 6px 16px
    border-radius 6px
    border 1px solid var(--color-footer-border)
    color var(--color-footer-text)
    font-weight 500
    font-size 14px
    background var(--color-card-bg)
    backdrop-filter blur(8px)
    text-decoration none
    transition all 0.25s cubic-bezier(0.4, 0, 0.2, 1)
    position relative
    overflow hidden
    cursor pointer
    svg {
      width 16px
      height 16px
      flex-shrink 0
      transition transform 0.25s ease
    }
    &::before {
      content ''
      position absolute
      top 50%
      left 50%
      width 0
      height 0
      background rgba(102, 126, 234, 0.15)
      border-radius 50%
      transform translate(-50%, -50%)
      transition width 0.4s ease, height 0.4s ease
    }
    &:hover {
      border-color #667eea
      color #667eea
      background rgba(102, 126, 234, 0.08)
      box-shadow 0 2px 12px rgba(102, 126, 234, 0.25)
      transform translateY(-2px)
      svg {
        transform scale(1.15)
      }
      &::before {
        width 120%
        height 120%
      }
    }
    &:active {
      transform scale(0.95)
      box-shadow 0 1px 4px rgba(102, 126, 234, 0.2)
    }
  }

  /* 图标颜色 */
  .nav-icon.icon-command {
    color #f59e0b
  }
  .nav-icon.icon-list {
    color #667eea
  }
  .nav-icon.icon-script {
    color #10b981
  }
  .nav-icon.icon-doc {
    color #8b5cf6
  }

  /* 暗色模式导航链接 */
  [data-color-mode*='dark'] & .nav-link {
    background transparent
    border-color rgba(255,255,255,0.15)
    color #c9d1d9
    &::before {
      background rgba(255,255,255,0.05)
    }
    &:hover {
      border-color #58a6ff
      color #58a6ff
      box-shadow 0 2px 12px rgba(88, 166, 255, 0.2)
    }
    &:active {
      border-color #58a6ff
      color #58a6ff
      background rgba(88, 166, 255, 0.15)
      box-shadow 0 1px 4px rgba(88, 166, 255, 0.15)
      transform scale(0.95)
    }
  }

  /* 暗色模式图标颜色 */
  [data-color-mode*='dark'] .nav-icon.icon-command {
    color #fbbf24
  }
  [data-color-mode*='dark'] .nav-icon.icon-list {
    color #58a6ff
  }
  [data-color-mode*='dark'] .nav-icon.icon-script {
    color #34d399
  }
  [data-color-mode*='dark'] .nav-icon.icon-doc {
    color #a78bfa
  }

  /* 广告位卡片美化 */
  .ad {
    display flex
    justify-content center
    flex-wrap wrap
    gap 16px
    margin-top 20px
    a {
      display inline-block
      padding 12px 20px
      border-radius 12px
      background linear-gradient(135deg, rgba(102, 126, 234, 0.06) 0%, rgba(118, 75, 162, 0.06) 100%)
      border 1px solid rgba(102, 126, 234, 0.15)
      transition all 0.3s cubic-bezier(0.4, 0, 0.2, 1)
      position relative
      overflow hidden
      &:hover {
        transform translateY(-3px)
        box-shadow 0 6px 20px rgba(102, 126, 234, 0.2)
        border-color rgba(102, 126, 234, 0.3)
      }
      b {
        display block
        font-size 14px
        color #333
        font-weight 600
      }
    }
    .ad_title {
      display block
      font-size 12px
      color #666
      margin-bottom 8px
      padding-top 0
    }
  }

  /* 暗色模式广告位 */
  [data-color-mode*='dark'] & .ad a {
    background linear-gradient(135deg, rgba(88, 166, 255, 0.06) 0%, rgba(121, 192, 255, 0.06) 100%)
    border-color rgba(88, 166, 255, 0.15)
    &:hover {
      box-shadow 0 6px 20px rgba(88, 166, 255, 0.2)
      border-color rgba(88, 166, 255, 0.3)
    }
    b {
      color #c9d1d9
    }
  }

  .stats-info {
    display flex
    justify-content center
    align-items center
    flex-wrap wrap
    gap 12px
    font-size 14px
    .stat-group {
      display inline-flex
      align-items center
      gap 6px
      padding 8px 18px
      border-radius 10px
      border 1px solid rgba(102, 126, 234, 0.2)
      color #4a5568
      font-weight 500
      font-size 14px
      background rgba(255, 255, 255, 0.7)
      backdrop-filter blur(8px)
      text-decoration none
      transition all 0.3s cubic-bezier(0.4, 0, 0.2, 1)
      position relative
      overflow hidden
      cursor pointer
      &::before {
        content ''
        position absolute
        top 50%
        left 50%
        width 0
        height 0
        background rgba(102, 126, 234, 0.15)
        border-radius 50%
        transform translate(-50%, -50%)
        transition width 0.4s ease, height 0.4s ease
        pointer-events none
      }
      &:hover {
        border-color #667eea
        color #667eea
        box-shadow 0 4px 16px rgba(102, 126, 234, 0.25)
        transform translateY(-3px)
        .github-icon {
          transform rotate(10deg) scale(1.1)
        }
        .stat-icon {
          transform scale(1.2)
        }
        &::before {
          width 150%
          height 150%
        }
      }
      &:active {
        transform scale(0.95)
        box-shadow 0 2px 8px rgba(102, 126, 234, 0.2)
      }
    }
    .stat-icon {
      width 16px
      height 16px
      flex-shrink 0
      transition transform 0.3s ease
    }
    .stat-icon.stat-icon-command {
      color #f59e0b
    }
    .stat-icon.stat-icon-script {
      color #10b981
    }
    .stat-icon.stat-icon-total {
      color #d6a400
    }
    .stat-label {
      font-weight 400
      color #4a5568
    }
    .stat-item {
      font-weight bold
      font-size 1.15em
    }
    .command {
      color #667eea
    }
    .script {
      color #f093fb
    }
    .total {
      color #d6a400
    }
    .github-btn {
      .github-icon + span {
        color inherit
      }
    }
  }
  [data-color-mode*='dark'] & .stats-info .stat-group {
    background transparent
    border-color rgba(255,255,255,0.15)
    color #c9d1d9
    &::before {
      background rgba(255,255,255,0.05)
    }
    &:hover {
      border-color #58a6ff
      color #58a6ff
      box-shadow 0 2px 12px rgba(88, 166, 255, 0.2)
    }
    &:active {
      box-shadow 0 1px 4px rgba(88, 166, 255, 0.15)
    }
  }
  [data-color-mode*='dark'] & .stats-info .stat-label {
    color #c9d1d9
  }
  [data-color-mode*='dark'] & .stats-info .stat-group .github-icon + span {
    color #c9d1d9
  }
  [data-color-mode*='dark'] & .stats-info .command {
    color #58a6ff
  }
  [data-color-mode*='dark'] & .stats-info .script {
    color #f093fb
  }
  [data-color-mode*='dark'] & .stats-info .total {
    color #f0c040
  }
  /* 暗色模式统计图标颜色 */
  [data-color-mode*='dark'] .stat-icon.stat-icon-command {
    color #fbbf24
  }
  [data-color-mode*='dark'] .stat-icon.stat-icon-script {
    color #34d399
  }
  [data-color-mode*='dark'] .stat-icon.stat-icon-total {
    color #fbbf24
  }
  .github-icon {
    transition transform 0.25s cubic-bezier(0.4, 0, 0.2, 1)
  }
}
