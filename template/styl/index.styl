/* ===== 404 页面 ===== */
.page-404 {
  min-height 100vh
  display flex
  flex-direction column
  align-items center
  justify-content center
  padding 40px 20px
  text-align center
  position relative
  &::before {
    content ''
    position absolute
    top 20%
    left 10%
    width 120px
    height 120px
    background radial-gradient(circle, rgba(102, 126, 234, 0.08) 0%, transparent 70%)
    border-radius 50%
    animation floatGlow 4s ease-in-out infinite
  }
  &::after {
    content ''
    position absolute
    bottom 20%
    right 10%
    width 100px
    height 100px
    background radial-gradient(circle, rgba(118, 75, 162, 0.06) 0%, transparent 70%)
    border-radius 50%
    animation floatGlow 4s ease-in-out infinite 2s
  }
  .error-code {
    font-size 140px
    font-weight 800
    line-height 1
    background linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%)
    -webkit-background-clip text
    -webkit-text-fill-color transparent
    background-clip text
    margin-bottom 16px
    letter-spacing -0.04em
    animation errorFloat 3s ease-in-out infinite
    text-shadow 0 20px 40px rgba(102, 126, 234, 0.2)
  }
  .error-title {
    font-size 28px
    font-weight 700
    color #1a1a2e
    margin-bottom 16px
    position relative
    &::after {
      content ''
      display block
      width 60px
      height 3px
      background linear-gradient(90deg, #667eea, #764ba2)
      margin 12px auto 0
      border-radius 2px
    }
  }
  .error-desc {
    font-size 17px
    color #6b7280
    margin-bottom 40px
    max-width 420px
    line-height 1.6
  }
  .error-actions {
    display flex
    gap 16px
    flex-wrap wrap
    justify-content center
  }
  .error-btn {
    display inline-flex
    align-items center
    gap 8px
    padding 14px 28px
    border-radius 12px
    font-size 16px
    font-weight 600
    text-decoration none
    transition all 0.3s cubic-bezier(0.4, 0, 0.2, 1)
    cursor pointer
    border none
    &.btn-primary {
      background linear-gradient(135deg, #667eea 0%, #764ba2 100%)
      color #fff
      box-shadow 0 6px 24px rgba(102, 126, 234, 0.35)
      &:hover {
        transform translateY(-3px)
        box-shadow 0 10px 32px rgba(102, 126, 234, 0.45)
      }
      &:active {
        transform translateY(0)
      }
    }
    &.btn-secondary {
      background rgba(102, 126, 234, 0.08)
      color #667eea
      border 1px solid rgba(102, 126, 234, 0.2)
      &:hover {
        background rgba(102, 126, 234, 0.12)
        border-color rgba(102, 126, 234, 0.3)
        transform translateY(-3px)
        box-shadow 0 6px 20px rgba(102, 126, 234, 0.2)
      }
    }
    svg {
      width 18px
      height 18px
    }
  }
  .error-illustration {
    margin-bottom 40px
    opacity 0.7
    svg {
      width 180px
      height 180px
    }
  }
}

@keyframes floatGlow {
  0%, 100% {
    transform translateY(0) scale(1)
    opacity 0.6
  }
  50% {
    transform translateY(-15px) scale(1.1)
    opacity 0.9
  }
}

@keyframes errorFloat {
  0%, 100% {
    transform translateY(0)
  }
  50% {
    transform translateY(-8px)
  }
}

[data-color-mode*='dark'] .page-404 {
  .error-code {
    background linear-gradient(135deg, #58a6ff 0%, #79c0ff 50%, #f093fb 100%)
    -webkit-background-clip text
    background-clip text
  }
  .error-title {
    color #e6edf3
  }
  .error-desc {
    color #8b949e
  }
  .error-btn {
    &.btn-secondary {
      background rgba(88, 166, 255, 0.08)
      color #58a6ff
      border-color rgba(88, 166, 255, 0.15)
      &:hover {
        background rgba(88, 166, 255, 0.12)
        border-color rgba(88, 166, 255, 0.25)
      }
    }
  }
}

/* ===== 页面加载过渡动画 ===== */
.page-transition-overlay {
  position fixed
  inset 0
  z-index 99999
  pointer-events none
  &::before {
    content ''
    position absolute
    inset 0
    background var(--color-theme-bg, #f5f7fa)
    opacity 0
    transition opacity 0.2s ease
  }
  &.loading::before {
    opacity 1
  }
}

[data-color-mode*='dark'] .page-transition-overlay::before {
  background var(--color-theme-bg, #0d1117)
}

/* 页面链接点击时触发过渡 */
a.page-transition {
  position relative
}

/* ============================================================
   新增美化：搜索快捷键提示 / 代码块复制提示 / 分类图标动画
   / 背景纹理 / 暗色滚动条 / placeholder打字机 / 骨架屏
   ============================================================ */

/* ----------------------------------------
   ① 搜索框底部快捷键提示
   ---------------------------------------- */
.search-shortcuts {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 12px;
  padding: 8px 16px;
  font-size: 12px;
  color: #9ca3af;
  opacity: 0;
  transform: translateY(4px);
  transition: opacity 0.25s ease, transform 0.25s ease;
  pointer-events: none;
  user-select: none;
}
.search-shortcuts.visible {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}
.shortcut-key {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  .key {
    display: inline-block;
    padding: 1px 6px;
    border-radius: 4px;
    border: 1px solid rgba(102, 126, 234, 0.25);
    background rgba(102, 126, 234, 0.06);
    color: #667eea;
    font-size: 11px;
    font-weight: 600;
    font-family: 'SF Mono', Consolas, monospace;
    line-height: 1.6;
    box-shadow: 0 1px 0 rgba(102, 126, 234, 0.2);
  }
}
[data-color-mode*='dark'] .search-shortcuts {
  color: #6b7280;
}
[data-color-mode*='dark'] .shortcut-key .key {
  border-color: rgba(88, 166, 255, 0.25);
  background: rgba(88, 166, 255, 0.08);
  color: #58a6ff;
  box-shadow: 0 1px 0 rgba(88, 166, 255, 0.2);
}

/* ----------------------------------------
   ③ 代码块底部"点击复制"提示条
   ---------------------------------------- */
.code-copy-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  padding: 6px 0 4px;
  font-size: 11px;
  color: #9ca3af;
  opacity: 0;
  transform: translateY(-4px);
  transition: opacity 0.25s ease, transform 0.25s ease, color 0.2s ease;
  cursor: default;
  user-select: none;
  pointer-events: none;
}
pre:hover + .code-copy-hint,
.code-block:hover .code-copy-hint,
.markdown-body pre:hover .code-copy-hint {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}
.code-copy-hint svg {
  width: 12px;
  height: 12px;
  color: #9ca3af;
  transition: color 0.2s ease;
}
pre:hover .code-copy-hint svg,
.code-block:hover .code-copy-hint svg,
.markdown-body pre:hover .code-copy-hint svg {
  color: #667eea;
}
[data-color-mode*='dark'] .code-copy-hint {
  color: #6b7280;
}
[data-color-mode*='dark'] .code-copy-hint svg {
  color: #6b7280;
}
[data-color-mode*='dark'] pre:hover .code-copy-hint svg,
[data-color-mode*='dark'] .code-block:hover .code-copy-hint svg,
[data-color-mode*='dark'] .markdown-body pre:hover .code-copy-hint svg {
  color: #58a6ff;
}

/* ----------------------------------------
   ⑥ 分类标题入场动画（内联SVG图标）
   ---------------------------------------- */
.section-title {
  opacity: 0;
  transform: translateX(-12px);
  transition: opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1),
              transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  .section-icon {
    display: inline-block;
    width: 18px;
    height: 18px;
    vertical-align: middle;
    margin-right: 6px;
    flex-shrink: 0;
    animation: none;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }
}
.section-title.visible {
  opacity: 1;
  transform: translateX(0);
  .section-icon {
    animation: icon-pop 0.5s cubic-bezier(0.4, 0, 0.2, 1) 0.1s both;
  }
}
@keyframes icon-pop {
  0% { transform: scale(0) rotate(-20deg); opacity: 0; }
  60% { transform: scale(1.2) rotate(5deg); opacity: 1; }
  100% { transform: scale(1) rotate(0deg); opacity: 1; }
}

/* 列表项滚动入场（已有 slide-item 基础，这里叠加交错延迟） */
.hotlist li:nth-child(1) { transition-delay: 0ms; }
.hotlist li:nth-child(2) { transition-delay: 40ms; }
.hotlist li:nth-child(3) { transition-delay: 80ms; }
.hotlist li:nth-child(4) { transition-delay: 120ms; }
.hotlist li:nth-child(5) { transition-delay: 160ms; }
.hotlist li:nth-child(n+6) { transition-delay: 200ms; }

/* ----------------------------------------
   ⑩ One Dark 代码高亮（暗色模式增强）
   ---------------------------------------- */
[data-color-mode*='dark'] markdown-style code,
[data-color-mode*='dark'] markdown-style pre,
[data-color-mode*='dark'] pre[class*="language-"],
[data-color-mode*='dark'] .wt-cli-code-block code {
  color: #abb2bf;
  /* 关键字 - 粉紫色 */
  .hljs-keyword,
  .hljs-selector-tag,
  .hljs-built_in,
  .hljs-name,
  .hljs-tag { color: #c678dd; }
  /* 字符串 - 青绿色 */
  .hljs-string,
  .hljs-title,
  .hljs-section,
  .hljs-attribute,
  .hljs-literal,
  .hljs-template-tag,
  .hljs-template-variable,
  .hljs-type { color: #98c379; }
  /* 数字 - 橙黄色 */
  .hljs-number,
  .hljs-symbol,
  .hljs-bullet,
  .hljs-link { color: #d19a66; }
  /* 注释 - 灰色斜体 */
  .hljs-comment,
  .hljs-quote { color: #5c6370; font-style: italic; }
  /* 变量/函数名 - 浅蓝色 */
  .hljs-variable,
  .hljs-attr,
  .hljs-params,
  .hljs-function { color: #61afef; }
  /* 操作符/标点 */
  .hljs-punctuation { color: #abb2bf; }
  /* 重要高亮 */
  .hljs-doctag,
  .hljs-meta { color: #e5c07b; }
  /* 删除线 */
  .hljs-deletion { color: #e06c75; background: rgba(224, 108, 117, 0.1); }
  /* 插入 */
  .hljs-addition { color: #98c379; background: rgba(152, 195, 121, 0.1); }
}

/* ----------------------------------------
   ⑪ 背景网格/噪点纹理
   ---------------------------------------- */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  z-index: -1;
  pointer-events: none;
  opacity: 0.4;
  /* 蜂窝六边形 */
  background-color: transparent;
  background-image:
    linear-gradient(30deg, rgba(102, 126, 234, 0.04) 12%, transparent 12.5%, transparent 87%, rgba(102, 126, 234, 0.04) 87.5%, rgba(102, 126, 234, 0.04)),
    linear-gradient(150deg, rgba(102, 126, 234, 0.04) 12%, transparent 12.5%, transparent 87%, rgba(102, 126, 234, 0.04) 87.5%, rgba(102, 126, 234, 0.04)),
    linear-gradient(30deg, rgba(102, 126, 234, 0.04) 12%, transparent 12.5%, transparent 87%, rgba(102, 126, 234, 0.04) 87.5%, rgba(102, 126, 234, 0.04)),
    linear-gradient(150deg, rgba(102, 126, 234, 0.04) 12%, transparent 12.5%, transparent 87%, rgba(102, 126, 234, 0.04) 87.5%, rgba(102, 126, 234, 0.04)),
    linear-gradient(60deg, rgba(118, 75, 162, 0.03) 25%, transparent 25.5%, transparent 75%, rgba(118, 75, 162, 0.03) 75%, rgba(118, 75, 162, 0.03)),
    linear-gradient(60deg, rgba(118, 75, 162, 0.03) 25%, transparent 25.5%, transparent 75%, rgba(118, 75, 162, 0.03) 75%, rgba(118, 75, 162, 0.03));
  background-size: 56px 98px;
  background-position: 0 0, 0 0, 28px 49px, 28px 49px, 0 0, 28px 49px;
}
[data-color-mode*='dark'] body::before {
  opacity: 0.35;
  background-image:
    linear-gradient(30deg, rgba(88, 166, 255, 0.05) 12%, transparent 12.5%, transparent 87%, rgba(88, 166, 255, 0.05) 87.5%, rgba(88, 166, 255, 0.05)),
    linear-gradient(150deg, rgba(88, 166, 255, 0.05) 12%, transparent 12.5%, transparent 87%, rgba(88, 166, 255, 0.05) 87.5%, rgba(88, 166, 255, 0.05)),
    linear-gradient(30deg, rgba(88, 166, 255, 0.05) 12%, transparent 12.5%, transparent 87%, rgba(88, 166, 255, 0.05) 87.5%, rgba(88, 166, 255, 0.05)),
    linear-gradient(150deg, rgba(88, 166, 255, 0.05) 12%, transparent 12.5%, transparent 87%, rgba(88, 166, 255, 0.05) 87.5%, rgba(88, 166, 255, 0.05)),
    linear-gradient(60deg, rgba(121, 192, 255, 0.03) 25%, transparent 25.5%, transparent 75%, rgba(121, 192, 255, 0.03) 75%, rgba(121, 192, 255, 0.03)),
    linear-gradient(60deg, rgba(121, 192, 255, 0.03) 25%, transparent 25.5%, transparent 75%, rgba(121, 192, 255, 0.03) 75%, rgba(121, 192, 255, 0.03));
}

/* ----------------------------------------
   ⑬ 暗色滚动条颜色统一
   ---------------------------------------- */
[data-color-mode*='dark'] {
  ::-webkit-scrollbar {
    width: 8px;
    height: 8px;
  }
  ::-webkit-scrollbar-track {
    background: rgba(255, 255, 255, 0.03);
    border-radius: 4px;
  }
  ::-webkit-scrollbar-thumb {
    background: rgba(88, 166, 255, 0.3);
    border-radius: 4px;
    transition: background 0.2s ease;
    &:hover {
      background: rgba(88, 166, 255, 0.5);
    }
    &:active {
      background: rgba(88, 166, 255, 0.7);
    }
  }
  /* Firefox */
  scrollbar-width: thin;
  scrollbar-color: rgba(88, 166, 255, 0.3) rgba(255, 255, 255, 0.03);
}

/* 亮色模式滚动条（可选，保持轻盈） */
[data-color-mode*='light'] {
  ::-webkit-scrollbar-thumb {
    background: rgba(102, 126, 234, 0.2);
    border-radius: 4px;
    transition: background 0.2s ease;
    &:hover {
      background: rgba(102, 126, 234, 0.35);
    }
  }
}

/* ----------------------------------------
   ⑮ placeholder 打字机（已由 index.js 控制）
   ---------------------------------------- */

/* ----------------------------------------
   ⑯ 骨架屏 HTML 结构（页面初始化时短暂显示）
   ---------------------------------------- */
.skeleton-wrap {
  padding: 30px 27px;
  .skeleton-block {
    background: linear-gradient(90deg,
      rgba(102, 126, 234, 0.05) 25%,
      rgba(102, 126, 234, 0.1) 50%,
      rgba(102, 126, 234, 0.05) 75%
    );
    background-size: 200% 100%;
    animation: skeleton-shimmer 1.6s ease-in-out infinite;
    border-radius: 10px;
    margin-bottom: 10px;
  }
  .sk-header {
    height: 52px;
    width: 80%;
    max-width: 500px;
  }
  .sk-tagline {
    height: 18px;
    width: 55%;
    margin-top: 12px;
  }
  .sk-divider {
    height: 1px;
    margin: 20px 0;
    background: none;
  }
  .sk-row {
    height: 52px;
  }
  .sk-row-sm {
    height: 36px;
  }
}
@keyframes skeleton-shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
[data-color-mode*='dark'] .skeleton-wrap .skeleton-block {
  background: linear-gradient(90deg,
    rgba(255, 255, 255, 0.03) 25%,
    rgba(255, 255, 255, 0.07) 50%,
    rgba(255, 255, 255, 0.03) 75%
  );
  background-size: 200% 100%;
}

/* ----------------------------------------
   ⑯ 分类图标 SVG（覆盖背景图方案）
   ---------------------------------------- */
.section-title {
  &::before { display: none; }
  .section-icon-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 6px;
    flex-shrink: 0;
    margin-right: 8px;
    vertical-align: middle;
  }
}

/* 命令分类图标 */
.section-title.command-title .section-icon-wrap {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.15), rgba(118, 75, 162, 0.15));
  color: #58a6ff;
}
[data-color-mode*='dark'] .section-title.script-section .section-icon-wrap {
  background: linear-gradient(135deg, rgba(240, 147, 251, 0.15), rgba(245, 87, 108, 0.15));
  color: #f093fb;
}

/* ============================================================
   ① 首页 Hero 区域 - 副标题、统计数字、入场动效
   ============================================================ */
.hero-section {
  max-width: 920px;
  margin: 40px auto 60px;
  padding: 0 27px;
  text-align: center;
  opacity: 0;
  transform: translateY(30px);
  transition: opacity 0.6s cubic-bezier(0.4, 0, 0.2, 1), transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}
.hero-section.hero-visible {
  opacity: 1;
  transform: translateY(0);
}
.hero-tagline {
  font-size: 22px;
  font-weight: 600;
  color: var(--color-footer-text);
  margin: 0 0 12px;
  letter-spacing: -0.02em;
}
[data-color-mode*='dark'] .hero-tagline {
  color: #e6edf3;
}
.hero-desc {
  font-size: 15px;
  color: #6b7280;
  margin: 0 0 32px;
  line-height: 1.6;
}
[data-color-mode*='dark'] .hero-desc {
  color: #8b949e;
}
.hero-stats {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 48px;
  flex-wrap: wrap;
}
.hero-stat {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 16px 28px;
  background: var(--color-card-bg);
  border-radius: 14px;
  border: 1px solid var(--color-footer-border);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
.hero-stat:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 24px rgba(102, 126, 234, 0.15);
  border-color: rgba(102, 126, 234, 0.25);
}
[data-color-mode*='dark'] .hero-stat:hover {
  box-shadow: 0 8px 24px rgba(88, 166, 255, 0.15);
  border-color: rgba(88, 166, 255, 0.25);
}
.hero-stat .stat-icon {
  width: 28px;
  height: 28px;
  color: #667eea;
}
[data-color-mode*='dark'] .hero-stat .stat-icon {
  color: #58a6ff;
}
.hero-stat .stat-number {
  font-size: 32px;
  font-weight: 700;
  color: #667eea;
  font-variant-numeric: tabular-nums;
}
[data-color-mode*='dark'] .hero-stat .stat-number {
  color: #58a6ff;
}
.hero-stat .stat-label {
  font-size: 14px;
  color: #6b7280;
}
[data-color-mode*='dark'] .hero-stat .stat-label {
  color: #8b949e;
}

/* ============================================================
   ⑥ 命令头部信息卡片（详情页）
   ============================================================ */
.command-header-card {
  background: var(--color-card-bg);
  border-radius: 16px;
  padding: 24px 28px;
  margin-bottom: 24px;
  border: 1px solid var(--color-footer-border);
  box-shadow: 0 2px 12px rgba(102, 126, 234, 0.08);
  backdrop-filter: blur(12px);
}
[data-color-mode*='dark'] .command-header-card {
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.2);
}
.command-title-row {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 12px;
}
.command-name {
  font-size: 32px;
  font-weight: 800;
  margin: 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
[data-color-mode*='dark'] .command-name {
  background: linear-gradient(135deg, #58a6ff 0%, #79c0ff 100%);
  -webkit-background-clip: text;
  background-clip: text;
}
.command-type-badge {
  display: inline-flex;
  align-items: center;
  padding: 6px 14px;
  border-radius: 20px;
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.3px;
}
.command-type-badge.command {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.15) 0%, rgba(118, 75, 162, 0.15) 100%);
  color: #667eea;
}
.command-type-badge.script {
  background: linear-gradient(135deg, rgba(240, 147, 251, 0.15) 0%, rgba(245, 87, 108, 0.15) 100%);
  color: #f093fb;
}
[data-color-mode*='dark'] .command-type-badge.command {
  background: linear-gradient(135deg, rgba(88, 166, 255, 0.15) 0%, rgba(121, 192, 255, 0.15) 100%);
  color: #58a6ff;
}
[data-color-mode*='dark'] .command-type-badge.script {
  background: linear-gradient(135deg, rgba(240, 147, 251, 0.15) 0%, rgba(245, 87, 108, 0.15) 100%);
  color: #f093fb;
}
.command-desc {
  font-size: 16px;
  color: #4a5568;
  margin: 0 0 20px;
  line-height: 1.6;
}
[data-color-mode*='dark'] .command-desc {
  color: #8b949e;
}
.command-actions {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-wrap: wrap;
}
.action-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 10px 18px;
  border-radius: 10px;
  font-size: 14px;
  font-weight: 500;
  text-decoration: none;
  color: #333;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.08) 0%, rgba(118, 75, 162, 0.08) 100%);
  border: 1px solid rgba(102, 126, 234, 0.2);
  cursor: pointer;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}
[data-color-mode*='dark'] .action-btn {
  color: #c9d1d9;
  background: linear-gradient(135deg, rgba(88, 166, 255, 0.08) 0%, rgba(121, 192, 255, 0.08) 100%);
  border-color: rgba(88, 166, 255, 0.2);
}
.action-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 16px rgba(102, 126, 234, 0.2);
  border-color: rgba(102, 126, 234, 0.35);
}
[data-color-mode*='dark'] .action-btn:hover {
  box-shadow: 0 4px 16px rgba(88, 166, 255, 0.2);
  border-color: rgba(88, 166, 255, 0.35);
}
.action-btn .action-icon {
  width: 16px;
  height: 16px;
  opacity: 0.8;
}
.action-btn:hover .action-icon {
  opacity: 1;
}

/* ============================================================
   ⑩ 相关命令推荐（详情页底部）
   ============================================================ */
.related-commands {
  margin-top: 48px;
  padding-top: 32px;
  border-top: 1px solid var(--color-footer-border);
}
.related-title {
  display: flex;
  align-items: center;
  gap: 12px;
  font-size: 20px;
  font-weight: 700;
  color: var(--color-footer-text);
  margin-bottom: 20px;
}
.related-title svg {
  color: #667eea;
}
[data-color-mode*='dark'] .related-title svg {
  color: #58a6ff;
}
.related-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}
.related-item {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 10px 18px;
  border-radius: 12px;
  background: var(--color-card-bg);
  border: 1px solid var(--color-footer-border);
  color: var(--color-footer-text);
  text-decoration: none;
  font-weight: 500;
  font-size: 14px;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}
.related-item:hover {
  transform: translateY(-3px);
  box-shadow: 0 6px 20px rgba(102, 126, 234, 0.18);
  border-color: #667eea;
  color: #667eea;
}
[data-color-mode*='dark'] .related-item:hover {
  box-shadow: 0 6px 20px rgba(88, 166, 255, 0.18);
  border-color: #58a6ff;
  color: #58a6ff;
}

/* ============================================================
   ⑭ 搜索框展开动画（列表页 Header）
   ============================================================ */
.header_list .search {
  min-width: 280px;
  transition: min-width 0.35s cubic-bezier(0.4, 0, 0.2, 1);
}
.header_list .search:focus-within {
  min-width: 400px;
}
@media screen and (max-width: 479px) {
  .header_list .search:focus-within {
    min-width: 260px;
  }
}

/* ============================================================
   ⑯ Logo 动态效果增强
   ============================================================ */
.header .logo a {
  position: relative;
  overflow: visible;
}
.header .logo a::after {
  content: '';
  position: absolute;
  inset: -8px;
  border-radius: 8px;
  background: radial-gradient(ellipse at center, rgba(102, 126, 234, 0.15) 0%, transparent 70%);
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.4s ease;
}
.header .logo a:hover::after {
  opacity: 1;
  animation: logoPulse 2s ease-in-out infinite;
}
@keyframes logoPulse {
  0%, 100% { transform: scale(1); opacity: 0.6; }
  50% { transform: scale(1.05); opacity: 1; }
}
[data-color-mode*='dark'] .header .logo a::after {
  background: radial-gradient(ellipse at center, rgba(88, 166, 255, 0.15) 0%, transparent 70%);
}

/* ============================================================
   ⑰ Footer 统计数字滚动动画
   ============================================================ */
.footer-count, .stat-number {
  display: inline-block;
  font-variant-numeric: tabular-nums;
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
.footer-count.count-animate, .stat-number.count-animate {
  animation: countPop 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}
@keyframes countPop {
  0% { transform: scale(1); }
  50% { transform: scale(1.15); }
  100% { transform: scale(1); }
}

/* ============================================================
   ⑲ 键盘快捷键 Ctrl+K 聚焦搜索
   ============================================================ */
.search-shortcuts {
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

/* ============================================================
   ⑳ 图片点击预览
   ============================================================ */
#img-preview-overlay {
  position: fixed;
  inset: 0;
  z-index: 99999;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.88);
  backdrop-filter: blur(12px);
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.25s ease;
}
#img-preview-overlay.active {
  opacity: 1;
  pointer-events: auto;
}
#img-preview-overlay img {
  max-width: 92%;
  max-height: 92%;
  border-radius: 12px;
  box-shadow: 0 12px 48px rgba(0, 0, 0, 0.4);
  transform: scale(0.92);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
#img-preview-overlay.active img {
  transform: scale(1);
}
#img-preview-overlay::after {
  content: '点击任意处关闭 | Esc 退出';
  position: absolute;
  bottom: 24px;
  left: 50%;
  transform: translateX(-50%);
  color: rgba(255, 255, 255, 0.5);
  font-size: 13px;
  padding: 8px 20px;
  border-radius: 20px;
  background: rgba(0, 0, 0, 0.5);
  pointer-events: none;
}

/* ============================================================
   ㉑ 404 页面搜索框
   ============================================================ */
.error-search {
  display: flex;
  justify-content: center;
  gap: 12px;
  margin: 32px 0;
  max-width: 480px;
  margin-left: auto;
  margin-right: auto;
}
.error-search-input {
  flex: 1;
  padding: 14px 20px;
  border-radius: 12px;
  border: 2px solid rgba(102, 126, 234, 0.2);
  background: var(--color-card-bg);
  color: var(--color-footer-text);
  font-size: 16px;
  outline: none;
  transition: all 0.25s ease;
}
.error-search-input:focus {
  border-color: #667eea;
  box-shadow: 0 0 0 4px rgba(102, 126, 234, 0.15);
}
[data-color-mode*='dark'] .error-search-input:focus {
  border-color: #58a6ff;
  box-shadow: 0 0 0 4px rgba(88, 166, 255, 0.15);
}
.error-search-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 14px 28px;
  border-radius: 12px;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-weight: 600;
  font-size: 16px;
  border: none;
  cursor: pointer;
  transition: all 0.25s ease;
}
.error-search-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(102, 126, 234, 0.35);
}
[data-color-mode*='dark'] .error-search-btn {
  background: linear-gradient(135deg, #58a6ff 0%, #79c0ff 100%);
}
.error-search-btn:hover {
  box-shadow: 0 6px 20px rgba(88, 166, 255, 0.35);
}

/* ============================================================
   ㉓ 页面切换过渡动画
   ============================================================ */
.page-transition-overlay {
  position: fixed;
  inset: 0;
  z-index: 99999;
  pointer-events: none;
}
.page-transition-overlay::before {
  content: '';
  position: absolute;
  inset: 0;
  background: var(--color-theme-bg, #f5f7fa);
  opacity: 0;
  transition: opacity 0.2s ease;
}
.page-transition-overlay.loading::before {
  opacity: 1;
}
[data-color-mode*='dark'] .page-transition-overlay::before {
  background: var(--color-theme-bg, #0d1117);
}

/* ============================================================
   ㉔ 404 页面终端风格 SVG 插图
   ============================================================ */
.terminal-404 {
  max-width: 240px;
  width: 100%;
}
[data-color-mode*='light'] .terminal-404 {
  stroke: #667eea;
  color: #333;
}
[data-color-mode*='dark'] .terminal-404 {
  stroke: #58a6ff;
  color: #c9d1d9;
}

/* ============================================================
   移动端响应式
   ============================================================ */
@media screen and (max-width: 479px) {
  .hero-section {
    margin: 20px auto 40px;
    padding: 0 16px;
  }
  .hero-tagline {
    font-size: 18px;
  }
  .hero-desc {
    font-size: 14px;
  }
  .hero-stats {
    gap: 20px;
  }
  .hero-stat {
    padding: 12px 20px;
    gap: 8px;
  }
  .hero-stat .stat-number {
    font-size: 24px;
  }
  .hero-stat .stat-label {
    font-size: 13px;
  }
  .command-header-card {
    padding: 18px 16px;
    margin-bottom: 16px;
  }
  .command-title-row {
    flex-wrap: wrap;
  }
  .command-name {
    font-size: 24px;
  }
  .command-actions {
    gap: 8px;
  }
  .action-btn {
    padding: 8px 14px;
    font-size: 13px;
  }
  .error-search {
    flex-direction: column;
    padding: 0 16px;
  }
  .error-search-input, .error-search-btn {
    width: 100%;
  }
  .related-commands {
    margin-top: 32px;
    padding-top: 24px;
  }
  .related-list {
    gap: 8px;
  }
  .related-item {
    padding: 8px 12px;
    font-size: 13px;
  }
  .related-desc {
    display: none;
  }
}

/* 补充：相关命令项内部元素样式 */
.related-name {
  font-weight: 600;
  color: inherit;
}

.related-desc {
  font-size: 12px;
  color: #6b7280;
  margin-left: 8px;
}

[data-color-mode*='dark'] .related-desc {
  color: #8b949e;
}